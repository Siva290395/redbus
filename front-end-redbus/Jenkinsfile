pipeline {
    agent any
    stages {
        stage('Checkout') {
            steps {
                git branch: 'master',
                    credentialsId: 'github-creds',
                    url: 'https://github.com/Siva290395/redbus.git'
            }
        }
        stage('Install') {
            steps {
                dir('front-end-redbus') {
                    sh '''
                        rm -rf node_modules package-lock.json
                        npm install --legacy-peer-deps
                        npm install postcss@8.4.31 postcss-safe-parser@5.0.5 --save-dev --legacy-peer-deps
                    '''
                }
            }
        }
        stage('Build') {
            steps {
                dir('front-end-redbus') {
                    sh '''
                        export NODE_OPTIONS="--openssl-legacy-provider --max-old-space-size=2048"
                        CI=false npm run build
                    '''
                }
            }
        }
        stage('Deploy') {
            steps {
                dir('front-end-redbus') {
                    sh '''
                        pm2 delete redbus-frontend || true
                        pm2 start "serve -s build -l 3000" --name "redbus-frontend"
                    '''
                }
            }
        }
    }
    post {
        success {
            echo "✅ Frontend deployed successfully!"
            echo "🌐 Website: http://10.13.124.110:3000"
        }
        failure {
            echo "❌ Frontend deployment failed. Check console logs above."
        }
    }
}
